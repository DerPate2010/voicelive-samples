# Optional local port. Azure App Service provides PORT automatically.
PORT=8080

# Optional for local development with a user-assigned managed identity.
# AZURE_CLIENT_ID=<managed-identity-client-id>

# Returned by POST /vlapi/token together with the access token.
AZURE_VOICELIVE_ENDPOINT=https://<your-ai-foundry-or-voice-live-endpoint>
AZURE_VOICELIVE_AGENT_NAME=<agent-name>
AZURE_VOICELIVE_PROJECT_NAME=<project-name>
